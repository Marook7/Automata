<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="org.example.demo.Controller"
      style="-fx-padding: 15; -fx-font-family: 'Segoe UI'; -fx-background-color: #f5f5f5;">

    <!-- Title -->
    <Label text="Automata Project" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #333;"/>
    <Separator/>

    <!-- Input Section -->
    <VBox spacing="8" style="-fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 10; -fx-background-color: white;">
        <Label text="Input String:" style="-fx-font-size: 12; -fx-font-weight: bold;"/>
        <TextField fx:id="inputField" promptText="Enter input string (e.g., aabb, 1010, 01)" 
                   style="-fx-font-size: 12; -fx-padding: 8; -fx-border-radius: 3;"/>
        <HBox spacing="10">
            <Button text="Clear" onAction="#handleClear" style="-fx-padding: 8 15; -fx-font-size: 11;"/>
        </HBox>
    </VBox>

    <!-- Tabs for different Automata -->
    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" 
             style="-fx-font-size: 12; -fx-padding: 10;">

        <!-- DFA Tab -->
        <Tab text="DFA" fx:id="dfaTab">
            <ScrollPane fitToWidth="true">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Deterministic Finite Automaton" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                    <Label text="Accepts binary strings divisible by 3 ending with 0" 
                           style="-fx-font-size: 11; -fx-text-fill: #666;"/>
                    <Label text="Examples: 0 ✓,  1110 ✓,  100 ✗" 
                           style="-fx-font-size: 10; -fx-text-fill: #999;"/>
                    <Button text="Test DFA" onAction="#handleDFA" 
                            style="-fx-padding: 10 30; -fx-font-size: 12; -fx-min-width: 150;"/>
                    <Label fx:id="dfaResultLabel" text="Status: Waiting for input" 
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #666; -fx-padding: 10; -fx-background-color: #f0f0f0; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-min-height: 40; -fx-wrap-text: true;"/>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- PDA Tab -->
        <Tab text="PDA" fx:id="pdaTab">
            <ScrollPane fitToWidth="true">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Pushdown Automaton" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                    <Label text="Accepts strings of form a^n b^n (equal 'a' followed by 'b')" 
                           style="-fx-font-size: 11; -fx-text-fill: #666;"/>
                    <Label text="Examples: aabb ✓,  aaabbb ✓,  aab ✗" 
                           style="-fx-font-size: 10; -fx-text-fill: #999;"/>
                    <Button text="Test PDA" onAction="#handlePDA" 
                            style="-fx-padding: 10 30; -fx-font-size: 12; -fx-min-width: 150;"/>
                    <Label fx:id="pdaResultLabel" text="Status: Waiting for input" 
                           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #666; -fx-padding: 10; -fx-background-color: #f0f0f0; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-min-height: 40; -fx-wrap-text: true;"/>
                </VBox>
            </ScrollPane>
        </Tab>

    </TabPane>

</VBox>
